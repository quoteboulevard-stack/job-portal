{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "lib": ["es2020", "dom"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "lib",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["index.ts", "types", "src/constants", "src/utils"],
  "exclude": ["node_modules", "lib", "src/__tests__", "graphify-out"]
}
