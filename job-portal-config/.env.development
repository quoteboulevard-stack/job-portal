# =============================================================================
# DEVELOPMENT ENVIRONMENT — local use only
# DO NOT commit this file. Add .env.development to .gitignore.
# Production values: Update in Firebase Console → Project Settings / Functions.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase — Client (public)
# Replace with your Firebase dev project values.
# -----------------------------------------------------------------------------
REACT_APP_FIREBASE_API_KEY=AIzaSy-REPLACE-WITH-DEV-KEY
REACT_APP_FIREBASE_AUTH_DOMAIN=job-portal-dev.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=job-portal-dev
REACT_APP_FIREBASE_STORAGE_BUCKET=job-portal-dev.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=000000000000
REACT_APP_FIREBASE_APP_ID=1:000000000000:web:REPLACE
REACT_APP_FIREBASE_MEASUREMENT_ID=G-REPLACE

# -----------------------------------------------------------------------------
# Stripe — Client (public, test publishable key)
# Use Stripe test-mode keys locally. Never use live keys in development.
# -----------------------------------------------------------------------------
REACT_APP_STRIPE_KEY=pk_test_REPLACE_WITH_STRIPE_TEST_PUBLISHABLE_KEY

# -----------------------------------------------------------------------------
# API — points to local dev server
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:5001

# =============================================================================
# BACKEND / SERVER-SIDE ONLY
# Run via: firebase functions:config or export locally before starting emulators
# =============================================================================

# Firebase Admin
FIREBASE_PROJECT_ID=job-portal-dev
FIREBASE_CLIENT_EMAIL=REPLACE@job-portal-dev.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=job-portal-dev.appspot.com

# Stripe — Secret (test mode)
# Production: Update in Firebase Console → Functions → Environment config
STRIPE_SECRET=sk_test_REPLACE_WITH_STRIPE_TEST_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_STRIPE_TEST_WEBHOOK_SECRET

# Razorpay (test mode)
# Production: Update in Firebase Console → Functions → Environment config
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_RAZORPAY_TEST_WEBHOOK_SECRET

# SendGrid
# Production: Update in Firebase Console → Functions → Environment config
SENDGRID_KEY=SG.REPLACE_WITH_SENDGRID_TEST_KEY
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=Job Portal

# Claude / Anthropic
# Production: Update in Firebase Console → Functions → Environment config
CLAUDE_API_KEY=sk-ant-REPLACE_WITH_CLAUDE_API_KEY
