# =============================================================================
# ENVIRONMENT VARIABLES — EXAMPLE
# Copy to .env.development (local) or set in your deployment platform.
# Never commit real keys. Update production values in Firebase Console.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase — Client (public)
# Source: Firebase Console → Project Settings → Your Apps
# -----------------------------------------------------------------------------
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Stripe — Client (public, publishable key only)
# Source: Stripe Dashboard → Developers → API Keys
# -----------------------------------------------------------------------------
REACT_APP_STRIPE_KEY=

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
REACT_APP_API_URL=

# =============================================================================
# BACKEND / SERVER-SIDE ONLY — never expose to client bundles
# =============================================================================

# Firebase Admin (server)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Stripe — Secret (server)
# Production: Update in Firebase Console → Functions → Environment config
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Razorpay (server)
# Production: Update in Firebase Console → Functions → Environment config
RAZORPAY_WEBHOOK_SECRET=

# SendGrid (server)
# Production: Update in Firebase Console → Functions → Environment config
SENDGRID_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=

# Claude / Anthropic (server)
# Production: Update in Firebase Console → Functions → Environment config
CLAUDE_API_KEY=
