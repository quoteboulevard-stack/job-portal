{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "rootDir": "src",
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "compileOnSave": true,
  "references": [
    { "path": "../../job-portal-shared-lib" }
  ],
  "include": [
    "src"
  ],
  "exclude": [
    "src/__tests__",
    "__tests__",
    "node_modules"
  ]
}
