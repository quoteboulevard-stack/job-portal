# Firebase Emulator — environment variables injected into Cloud Functions at runtime.
# This file is read automatically by the Firebase emulator when running functions.
# DO NOT commit real secrets. This file is for local development only.
FIREBASE_PROJECT_ID=demo-test
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
